entity User {
    name: String,
    age: Long,
    active: Bool,
    scores: Set<Long>,
    addr: ipaddr,
    balance: decimal,
    joined: datetime,
    session: duration,
    buddy: User,
    profile: {
        bio: String,
    },
};

entity Document {
    title: String,
};

action "view" appliesTo {
    principal: User,
    resource: Document,
    context: {},
};
