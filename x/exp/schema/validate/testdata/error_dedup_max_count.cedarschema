action "a6" appliesTo { principal: User, resource: Document, context: {} };
action "a7" appliesTo { principal: User, resource: Document, context: {} };
action "a8" appliesTo { principal: User, resource: Document, context: {} };
action "a9" appliesTo { principal: User, resource: Document, context: {} };
action "a10" appliesTo { principal: User, resource: Document, context: {} };
action "b1" appliesTo { principal: Admin, resource: Document, context: {} };
action "b2" appliesTo { principal: Admin, resource: Document, context: {} };
action "b3" appliesTo { principal: Admin, resource: Document, context: {} };
action "b4" appliesTo { principal: Admin, resource: Document, context: {} };
action "b5" appliesTo { principal: Admin, resource: Document, context: {} };
