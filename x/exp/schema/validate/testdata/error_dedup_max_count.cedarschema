entity User = {
    x: Long,
};
entity Admin = {
    x: String,
};
entity Document;

// Many actions with User principal (count=1 for the error) to ensure
// at least one comes before the Admin action (count=2)
action "a1" appliesTo { principal: User, resource: Document, context: {} };
action "a2" appliesTo { principal: User, resource: Document, context: {} };
action "a3" appliesTo { principal: User, resource: Document, context: {} };
